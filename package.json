{
  "name": "paramedic-event-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "overrides": {
    "react": "19.1.0",
    "react-native": "0.81.5",
    "@types/react": "~19.1.10"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:backend": "npm run start:dev -w @events/backend",
    "dev:mobile": "npm run start -w @events/mobile",
    "load:test": "node scripts/load-test.mjs",
    "docker:up": "docker compose up --build"
  }
}
