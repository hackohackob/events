{
  "name": "event",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "react": "19.1.0",
    "react-native": "0.81.5",
    "expo": "~54.0.33"
  },
  "overrides": {
    "react": "19.1.0",
    "react-native": "0.81.5",
    "@types/react": "~19.1.10"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:backend": "npm run start:dev -w @events/backend",
    "dev:web": "npm run dev -w @events/web",
    "build:web": "npm run build -w @events/web",
    "dev:mobile": "cd apps/mobile && npx expo start --dev-client",
    "dev:mobile:android": "cd apps/mobile && expo run:android",
    "load:test": "node scripts/load-test.mjs",
    "docker:up": "docker compose up --build",
    "reverse:proxy": "adb reverse tcp:8082 tcp:8082"
  },
  "devDependencies": {
    "@types/react": "~19.1.10"
  }
}
