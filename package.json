{
  "name": "event",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "expo": "~54.0.33",
    "expo-dev-client": "~6.0.21",
    "qrcode.react": "^4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5"
  },
  "overrides": {
    "react": "19.1.0",
    "react-native": "0.81.5",
    "@types/react": "~19.1.10",
    "react-native-reanimated": "4.1.1",
    "react-native-worklets": "0.5.1",
    "react-dom": "19.1.0"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:backend": "PORT=8500 POSTGRES_PORT=8502 REDIS_URL=redis://localhost:8501 npm run start:dev -w @events/backend",
    "dev:web": "npm run dev -w @events/web",
    "build:web": "npm run build -w @events/web",
    "dev:simulator": "npm run dev -w @events/simulator",
    "dev:mobile": "cd apps/mobile && ANDROID_HOME=/opt/homebrew/share/android-commandlinetools npx expo start --dev-client",
    "dev:mobile:android": "cd apps/mobile && ANDROID_HOME=/opt/homebrew/share/android-commandlinetools npx expo run:android --device",
    "load:test": "node scripts/load-test.mjs",
    "infra": "docker compose up postgres redis -d",
    "infra:down": "docker compose down",
    "docker:up": "docker compose up --build",
    "reverse:proxy": "adb ${ANDROID_SERIAL:+-s $ANDROID_SERIAL} reverse tcp:8500 tcp:8500"
  },
  "devDependencies": {
    "@types/react": "~19.1.10"
  },
  "packageManager": "npm@10.9.2"
}
